{
  "manifest_version": 3,
  "name": "Tailwind Config Extractor",
  "version": "1.0.0",
  "description": "Extract design tokens and generate tailwind.config.js from any website.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
    "background": {
        "service_worker": "src/core/background.ts",
        "type": "module"
    },
    "content_scripts": [
        {
        "matches": ["<all_urls>"],
        "js": ["src/core/scraper.ts"]
        }
    ]
}